##
# Test environment overrides
# Laravel merges this file on top of .env when APP_ENV=testing.
# These values ensure that ANY artisan command executed in the testing
# environment — whether via PHPUnit or the CLI — always targets the
# in-memory SQLite database, never the real MariaDB instance.
##

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array
