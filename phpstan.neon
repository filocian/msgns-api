includes:
  - vendor/larastan/larastan/extension.neon

parameters:
  level: 8
  paths:
    - src/Shared
    - src/Identity
    - src/Products
    - tools/phpstan
    - tests/Pest.php
    - tests/TestCase.php
    - tests/Datasets
    - tests/Architecture
  excludePaths:
    - src/*/Infrastructure/Persistence/*Model.php
    - src/Products/Infrastructure/Persistence/Eloquent*.php

services:
  - class: Tools\PHPStan\Rules\NoIlluminateInCoreLayers
    tags:
      - phpstan.rules.rule
